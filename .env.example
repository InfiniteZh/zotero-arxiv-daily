# Core Configuration
DEBUG=false
DELIVERY_MODE=feishu

# Zotero Configuration
ZOTERO_ID=your_zotero_user_id
ZOTERO_KEY=your_zotero_api_key
ZOTERO_INCLUDE_PATH=["2026/survey/**","2026/reading-group/**"]
ZOTERO_IGNORE_PATH=["archive/**"]

# Source Configuration
SOURCE_ARXIV_CATEGORY=["cs.CR","cs.SE","cs.AI","cs.CL","cs.LG","stat.ML","cs.HC","cs.CY"]
SOURCE_ARXIV_INCLUDE_CROSS_LIST=false
SOURCE_BIORXIV_CATEGORY=[]
SOURCE_MEDRXIV_CATEGORY=[]

# Feishu Configuration (when DELIVERY_MODE=feishu)
FEISHU_ENABLED=true
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook-id
FEISHU_BOT_NAME=arXiv Daily Bot
FEISHU_TIMEOUT=30
FEISHU_MAX_RETRIES=3

# Scheduling (optional)
# Set to HH:MM in 24-hour format for daily runs at that time.
# If not set, the container runs once and exits.
# SCHEDULE=09:00

# NanoClaw Configuration (optional, when DELIVERY_MODE=nanoclaw)
NANOCLAW_ENABLED=false
NANOCLAW_ENDPOINT=http://localhost:3000/api/paper-digests
NANOCLAW_TOKEN=
NANOCLAW_TIMEOUT=30
NANOCLAW_INCLUDE_FULL_TEXT=true
NANOCLAW_MAX_RETRIES=3

# Email Configuration (optional, when DELIVERY_MODE=email)
SENDER=your_email@qq.com
RECEIVER=receiver@outlook.com
SENDER_PASSWORD=your_smtp_auth_code

# OpenAI / LLM Configuration
OPENAI_API_KEY=your_llm_api_key
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
LLM_LANGUAGE=English

# Optional container proxy configuration for Docker build/runtime.
# If your local proxy listens on macOS localhost, use host.docker.internal
# instead of 127.0.0.1 so containers can reach it.
# CONTAINER_HTTP_PROXY=http://host.docker.internal:7897
# CONTAINER_HTTPS_PROXY=http://host.docker.internal:7897
# CONTAINER_NO_PROXY=localhost,127.0.0.1,::1,host.docker.internal

# Optional runtime tuning
HF_HUB_DISABLE_XET=1
